# NPM Registry credentials for @igrp packages
# Copy to .env.local and fill in your values.
# .env.local is gitignored and will NOT be committed.
#
# NPM_REGISTRY_PASSWORD must be base64-encoded (npm requirement).
# To encode: echo -n "your-password" | base64
# PowerShell: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("your-password"))
#
# Usage: npm/pnpm reads these from the environment. Options:
# 1. Export before install: $env:NPM_REGISTRY_USERNAME="..."; $env:NPM_REGISTRY_PASSWORD="..."
# 2. Use dotenv-cli: npx dotenv-cli -e .env.local -- pnpm install

NPM_REGISTRY_USERNAME=
NPM_REGISTRY_PASSWORD=
