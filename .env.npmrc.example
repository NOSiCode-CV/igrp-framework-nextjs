# NPM Registry credentials for @igrp packages
# Copy to .env.local and fill in your values.
# .env.local is gitignored and will NOT be committed.
#
# NPM_REGISTRY_PASSWORD must be base64-encoded (npm requirement).
# To encode: echo -n "your-password" | base64
# PowerShell: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("your-password"))
#
# Auth lines cannot live in the repo .npmrc with ${...}: if those vars are unset, pnpm may ignore
# the whole project .npmrc, so @igrp:registry is lost and installs hit registry.npmjs.org (404).
# Add the two lines below to your user npmrc (e.g. %USERPROFILE%\.npmrc), then use install:deps or export env.
#
# //sonatype.nosi.cv/repository/igrp/:username=${NPM_REGISTRY_USERNAME}
# //sonatype.nosi.cv/repository/igrp/:_password=${NPM_REGISTRY_PASSWORD}
#
# Usage: npm/pnpm reads these from the environment. Options:
# 1. Export before install: $env:NPM_REGISTRY_USERNAME="..."; $env:NPM_REGISTRY_PASSWORD="..."
# 2. pnpm run install:deps (loads .env then pnpm install)
# 3. npx dotenv-cli -e .env -- pnpm install

NPM_REGISTRY_USERNAME=
NPM_REGISTRY_PASSWORD=
