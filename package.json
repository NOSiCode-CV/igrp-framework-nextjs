{
  "name": "igrp-framework-nextjs",
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": [
    "packages/**",
    "templates/**"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean",
    "format": "pnpm -r run format",
    "build:framework": "pnpm --filter @igrp/framework-next build:prod",
    "build:framework-ui": "pnpm --filter @igrp/framework-next-ui build:prod",
    "build:framework-types": "pnpm --filter @igrp/framework-next-types build",
    "dev:framework": "pnpm --filter @igrp/framework-next dev",
    "run:framework": "pnpm build:framework-types && pnpm build:framework-ui && pnpm build:framework",
    "release:framework": "pnpm run:framework && pnpm -r run release",
    "clean:framework": "pnpm --filter @igrp/framework-next clean",
    "dev:demo": "pnpm --filter demo dev",
    "build:demo": "pnpm --filter demo build",
    "start:demo": "pnpm --filter demo start",
    "dev:contribuicoes": "pnpm --filter demo-contribuicoes dev"    
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.x.x"
  }
}