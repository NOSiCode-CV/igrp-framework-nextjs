{
  "name": "igrp-framework-nextjs",
  "version": "0.0.1-beta.114",
  "description": "IGRP Framework for Next.js",
  "keywords": [
    "igrp",
    "framework",
    "nextjs"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "workspaces": [
    "packages/**",
    "templates/**",
    "apps/**"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean",
    "format": "pnpm -r run format",
    "build:next": "pnpm --filter @igrp/framework-next build",
    "build:auth": "pnpm --filter @igrp/framework-next-auth build",
    "build:next-types": "pnpm --filter @igrp/framework-next-types build",
    "build:next-ui": "pnpm --filter @igrp/framework-next-ui build",
    "build:ds": "pnpm --filter @igrp/igrp-framework-react-design-system build",
    "build:framework": "pnpm build:auth && pnpm build:next-types && pnpm build:ds && pnpm build:next-ui && pnpm build:next",
    "storybook": "pnpm --filter @igrp/igrp-framework-react-design-system-storybook storybook",
    "test:storybook": "pnpm --filter @igrp/igrp-framework-react-design-system-storybook test-storybook",
    "dev:demo": "pnpm --filter @igrp/framework-next-template dev",
    "build:demo": "pnpm --filter @igrp/framework-next-template build",
    "start:demo": "pnpm --filter @igrp/framework-next-template start",
    "release:demo": "pnpm --filter @igrp/framework-next-template publish:template",
    "clean-all": "pnpm -r run clean-all",
    "changeset": "changeset",
    "version:changesets": "changeset version",
    "release:version": "changeset version",
    "release:build": "pnpm build:framework",
    "release:publish": "changeset publish",
    "release:all": "pnpm release:version && pnpm release:build && pnpm release:publish",
    "migrate:primitives": "node scripts/migrate-primitive-names.mjs",
    "migrate:primitives:apply": "node scripts/migrate-primitive-names.mjs --apply",
    "install:deps": "dotenv -e .env -- pnpm install",
    "template-migrations": "pnpm --filter @igrp/template-migrator build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.x.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
