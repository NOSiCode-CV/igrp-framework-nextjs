{
  "name": "igrp-framework-nextjs",
  "version": "0.0.1",
  "workspaces": [
    "packages/**",
    "templates/**"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "build:framework": "pnpm --filter @igrp/framework-next build",
    "dev": "pnpm --filter demo dev",
    "dev:framework": "pnpm --filter @igrp/framework-next dev",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean",
    "clean:framework": "pnpm --filter @igrp/framework-next clean",
    "format:framework": "pnpm --filter @igrp/framework-next format",
    "publish:framework": "pnpm --filter @igrp/framework-next deploy-to"
  },
  "devDependencies": {
    "eslint": "^9.29.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.x.x"
  }
}
