{
  "name": "@igrp/igrp-framework-react-design-system-storybook",
  "version": "0.0.1-beta.57",
  "description": "IGRP Design System Storybook",
  "type": "module",
  "author": {
    "name": "NOSi E.P.E - Núcleo Operacional Para a Sociedade de Informação",
    "email": "helpdesk@nosi.cv",
    "url": "https://igrp.cv"
  },
  "maintainers": [
    {
      "name": "NOSi E.P.E - Núcleo Operacional Para a Sociedade de Informação",
      "email": "helpdesk@nosi.cv",
      "url": "https://igrp.cv"
    }
  ],
   "license": "MIT",
  "scripts": {
    "dev": "tsc --watch",
    "storybook": "storybook dev -p 6006 --ci",
    "build-storybook": "storybook build",
    "serve-storybook": "pnpm dlx serve storybook-static -l 6006",
    "test-storybook": "test-storybook --url http://localhost:6006/storybook",
    "test-storybook:ci": "test-storybook --url http://localhost:6006/storybook --ci",
    "test-storybook:update-snapshots": "test-storybook --url http://localhost:6006/storybook -u",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "chromatic": "chromatic --exit-zero-on-changes",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "clean-all": "rimraf node_modules"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@igrp/igrp-framework-react-design-system": "0.1.0-beta.102",
    "@tailwindcss/vite": "^4.1.18",
    "next": "15.5.12",
    "react": "19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.1",
    "recharts": "^2.15.4",    
    "tailwindcss": "^4.1.16",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.1",
    "@storybook/test-runner": "^0.24.2",
    "@types/jest": "^29.5.14",
    "chromatic": "^11.3.3",
    "@eslint/js": "9.39.2",
    "@storybook/addon-a11y": "^10.2.8",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-onboarding": "^10.2.8",
    "@storybook/addon-vitest": "^10.2.8",
    "@storybook/nextjs-vite": "^10.2.8",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/browser": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "0.5.0",
    "eslint-plugin-storybook": "^10.2.8",
    "globals": "17.3.0",
    "playwright": "^1.58.2",
    "prettier": "3.8.1",
    "storybook": "^10.2.8",
    "storybook-addon-tag-badges": "^3.0.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.55.0",
    "vite": "7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.x.x",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.17.1",
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
