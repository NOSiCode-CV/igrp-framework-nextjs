{
  "name": "@igrp/igrp-framework-react-design-system-storybook",
  "version": "0.1.0-beta-141",
  "private": true,
  "description": "IGRP Design System Storybook",
  "type": "module",
  "author": {
    "name": "NOSi E.P.E - Núcleo Operacional Para a Sociedade de Informação",
    "email": "helpdesk@nosi.cv",
    "url": "https://igrp.cv"
  },
  "maintainers": [
    {
      "name": "NOSi E.P.E - Núcleo Operacional Para a Sociedade de Informação",
      "email": "helpdesk@nosi.cv",
      "url": "https://igrp.cv"
    }
  ],
  "license": "MIT",
  "scripts": {
    "dev": "tsc --watch",
    "storybook": "storybook dev -p 6006 --ci",
    "build-storybook": "storybook build",
    "serve-storybook": "pnpm dlx serve storybook-static -l 6006",
    "test-storybook": "test-storybook --url http://localhost:6006",
    "test-storybook:ci": "test-storybook --url http://localhost:6006 --ci",
    "test-storybook:update-snapshots": "test-storybook --url http://localhost:6006 -u",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "chromatic": "chromatic --exit-zero-on-changes",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "clean-all": "rimraf node_modules"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@igrp/igrp-framework-react-design-system": "0.1.0-beta.141",
    "@tailwindcss/vite": "4.3.1",
    "next": "15.5.19",
    "react": "19.2.7",
    "react-day-picker": "9.13.2",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "recharts": "3.9.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@storybook/test-runner": "0.24.4",
    "@types/jest": "30.0.0",
    "chromatic": "17.6.0",
    "@eslint/js": "9.39.4",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-onboarding": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/nextjs-vite": "10.4.6",
    "@types/node": "25.9.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-storybook": "10.4.6",
    "globals": "17.7.0",
    "playwright": "1.61.1",
    "prettier": "3.8.4",
    "storybook": "10.4.6",
    "storybook-addon-tag-badges": "3.1.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22.x.x"
  }
}
