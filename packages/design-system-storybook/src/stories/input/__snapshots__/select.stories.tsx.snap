          >
            <path d="m6 9 6 6 6-6">
            </path>
          </svg>
        </button>
        <select aria-hidden="true"
                tabindex="-1"
                style="position: absolute; border: 0px; width: 1px; height: 1px; padding: 0px; margin: -1px; overflow: hidden; clip: rect(0px, 0px, 0px, 0px); white-space: nowrap; overflow-wrap: normal;"
        >
          <option value
                  selected
          >
          </option>
          <option value="apple">
            AppleA sweet red fruit
          </option>
          <option value="banana">
            BananaA yellow fruit rich in potassium
          </option>
          <option value="carrot">
            CarrotAn orange root vegetable
          </option>
          <option value="broccoli">
            BroccoliA green vegetable
          </option>
          <option value="cheeseburger">
