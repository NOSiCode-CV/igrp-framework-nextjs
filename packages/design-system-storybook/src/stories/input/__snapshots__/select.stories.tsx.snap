          </option>
          <option value="user_1">
            Jane DoeProduct Manager
          </option>
          <option value="user_2">
            John SmithSoftware Engineer
          </option>
          <option value="user_3">
            Alice NguyenUX Designer
          </option>
        </select>
        <p data-slot="form-description"
           id="_r_ID_-form-item-description"
           class="text-muted-foreground text-sm"
        >
