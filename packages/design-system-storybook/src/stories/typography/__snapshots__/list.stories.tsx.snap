             class="lucide lucide-circle text-muted-foreground bg-transparent border-border h-1.5 w-1.5 fill-current"
             aria-hidden="true"
             id="Circle"
        >
          <circle cx="12"
                  cy="12"
                  r="10"
          >
          </circle>
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <div class="flex-1 text-secondary-foreground">
            Muted: Less prominent item
          </div>
        </div>
      </div>
    </div>
  </div>
</ul>
`;
