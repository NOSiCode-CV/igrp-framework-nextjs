{
  "package": "@igrp/igrp-framework-react-design-system",
  "components": [
    {
      "name": "IGRPButton",
      "category": "actions",
      "props": {
        "variant": ["default", "destructive", "outline", "secondary", "ghost", "link"],
        "size": ["default", "xs", "sm", "lg", "icon", "icon-sm", "icon-lg"]
      },
      "example": "<IGRPButton variant=\"default\">Save</IGRPButton>"
    },
    {
      "name": "IGRPForm",
      "category": "form",
      "props": {
        "schema": "ZodSchema",
        "onSubmit": "function",
        "formRef": "RefObject"
      },
      "example": "<IGRPForm schema={schema} onSubmit={handleSubmit} formRef={formRef}>...</IGRPForm>"
    },
    {
      "name": "IGRPFormField",
      "category": "form",
      "props": {
        "name": "string",
        "label": "string",
        "required": "boolean"
      },
      "example": "<IGRPFormField name=\"email\" label=\"Email\" required><IGRPInputText name=\"email\" /></IGRPFormField>"
    },
    {
      "name": "IGRPInputText",
      "category": "inputs",
      "props": {
        "name": "string",
        "type": ["text", "email", "password", "search", "url"],
        "label": "string",
        "placeholder": "string"
      },
      "example": "<IGRPInputText name=\"email\" type=\"email\" />"
    },
    {
      "name": "IGRPSelect",
      "category": "inputs",
      "props": {
        "name": "string",
        "options": "IGRPOptionsProps[]",
        "placeholder": "string"
      },
      "example": "<IGRPSelect name=\"role\" options={options} placeholder=\"Select\" />"
    },
    {
      "name": "IGRPDataTable",
      "category": "data",
      "props": {
        "columns": "ColumnDef<T>[]",
        "data": "T[]"
      },
      "example": "<IGRPDataTable columns={columns} data={data} />"
    },
    {
      "name": "IGRPCard",
      "category": "layout",
      "children": ["IGRPCardHeader", "IGRPCardTitle", "IGRPCardContent", "IGRPCardFooter"],
      "example": "<IGRPCard><IGRPCardHeader><IGRPCardTitle>Title</IGRPCardTitle></IGRPCardHeader><IGRPCardContent>Content</IGRPCardContent></IGRPCard>"
    },
    {
      "name": "IGRPModalDialog",
      "category": "overlay",
      "children": ["IGRPModalDialogTrigger", "IGRPModalDialogContent", "IGRPModalDialogHeader", "IGRPModalDialogTitle", "IGRPModalDialogFooter"],
      "example": "<IGRPModalDialog><IGRPModalDialogTrigger asChild><IGRPButton>Open</IGRPButton></IGRPModalDialogTrigger><IGRPModalDialogContent>...</IGRPModalDialogContent></IGRPModalDialog>"
    },
    {
      "name": "IGRPPageHeader",
      "category": "layout",
      "props": {
        "title": "string",
        "description": "string"
      },
      "example": "<IGRPPageHeader title=\"Page Title\">...</IGRPPageHeader>"
    }
  ]
}
