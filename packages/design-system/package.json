{
  "name": "@igrp/igrp-framework-react-design-system",
  "version": "0.1.0-beta.102",
  "description": "IGRP Design System components",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "layout",
    "components",
    "client side"
  ],
  "author": {
    "name": "NOSi E.P.E - Núcleo Operacional Para a Sociedade de Informação",
    "email": "helpdesk@nosi.cv",
    "url": "https://igrp.cv"
  },
  "maintainers": [
    {
      "name": "NOSi E.P.E - Núcleo Operacional Para a Sociedade de Informação",
      "email": "helpdesk@nosi.cv",
      "url": "https://igrp.cv"
    }
  ],
  "license": "MIT",
  "scripts": {
    "dev": "tsc --watch",
    "build": "pnpm build:reactcompiler",
    "build:babel": "rimraf dist_optimized && babel dist --out-dir dist_optimized --source-maps --extensions .ts,.js,.tsx,.jsx,.cjs,.mjs && rimraf dist && move dist_optimized dist && cpy src/*.css dist/",
    "build:reactcompiler": "pnpm clean:dist && pnpm tailwind:build && pnpm build:swc && pnpm build:babel && pnpm build:types",
    "build:swc": "swc ./src -d dist --config-file .swcrc --strip-leading-paths --ignore \"**/components/experimental/**\" && cpy src/*.css dist/",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/",
    "build:without_reactcompiler": "pnpm clean:dist && pnpm build:types && pnpm build:swc",
    "clean": "pnpm clean:dist && pnpm clean:packages",
    "clean:dist": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "clean:packages": "rimraf node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tailwind:build": "pnpm dlx @tailwindcss/cli -i ./src/index.css -o ./src/styles.css",
    "release": "pnpm format && pnpm build && yarn publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest",
    "clean-all": "rimraf node_modules && rimraf dist && rimraf tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "next": "^15.5.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@origin-space/image-cropper": "^0.1.9",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.564.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^9.11.3",
    "react-hook-form": "^7.71.1",
    "react-phone-number-input": "3.4.14",
    "react-resizable-panels": "^3.0.6",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.17",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@eslint/js": "^9.0.0",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.11",
    "@tailwindcss/cli": "^4.1.17",
    "@types/babel__preset-env": "7.10.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "cpy-cli": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "17.3.0",
    "move-cli": "^2.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.55.0"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens": "./dist/tokens.css",
    "./styles": "./dist/styles.css"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./tokens": "./dist/tokens.css",
      "./styles": "./dist/styles.css"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.x.x"
  }
}
