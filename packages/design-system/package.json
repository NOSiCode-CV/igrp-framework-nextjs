{
  "name": "@igrp/igrp-framework-react-design-system",
  "version": "0.0.1-alpha.27",
  "description": "IGRP Design System components",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "layout",
    "components",
    "client side"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "scripts": {
    "dev": "tsc --watch",
    "build": "pnpm build:reactcompiler",
    "build:babel": "rimraf dist_optimized && babel dist --out-dir dist_optimized --source-maps --extensions .ts,.js,.tsx,.jsx,.cjs,.mjs && rimraf dist && move dist_optimized dist && cpy src/*.css dist/",
    "build:reactcompiler": "rimraf dist && rimraf tsconfig.tsbuildinfo && pnpm tailwind:build && pnpm build:swc && pnpm build:babel && pnpm build:types",
    "build:swc": "swc ./src -d dist --config-file .swcrc --strip-leading-paths && cpy src/*.css dist/",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/",
    "build:without_reactcompiler": "rimraf dist && rimraf tsconfig.tsbuildinfo && pnpm build:types && pnpm build:swc",
    "clean": "pnpm clean:dist && pnpm clean:packages",
    "clean:dist": "rimraf {dist,*.tsbuildinfo}",
    "clean:packages": "rimraf node_modules",
    "format": "prettier --write .",
    "tailwind:build": "npx @tailwindcss/cli -i ./src/index.css -o ./src/styles.css",
    "release": "pnpm format && pnpm build && yarn publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest"
  },
  "peerDependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "@hookform/resolvers": "5.0.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "next-themes": "0.4.6",
    "react-day-picker": "^9.6.7",
    "react-dropzone": "14.3.8",
    "react-hook-form": "^7.55.0",
    "react-phone-number-input": "3.4.12",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.2",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@babel/cli": "7.27.2",
    "@babel/core": "7.27.3",
    "@babel/preset-env": "7.27.2",
    "@babel/preset-react": "7.27.1",
    "@babel/preset-typescript": "7.27.1",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.1",
    "@tailwindcss/cli": "^4.1.11",
    "@types/babel__preset-env": "7.10.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "19.1.6",
    "babel-plugin-react-compiler": "19.1.0-rc.2",
    "cpy-cli": "5.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.3",
    "move-cli": "^2.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./css": {
        "import": "./dist/index.css",
        "default": "./dist/index.css"
      },
      "./styles.css": "./dist/styles.css"      
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.x.x"
  }
}
