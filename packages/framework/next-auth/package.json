{
  "name": "@igrp/framework-next-auth",
  "version": "0.1.0-beta.13",
  "description": "IGRP Framework for Next.js | Auth",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js"
    },
    "./jwt": {
      "types": "./dist/jwt.d.ts",
      "import": "./dist/jwt.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },    
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "format": "prettier --write .",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "build:js": "tsup",
    "build": "pnpm clean && pnpm build:js && pnpm build:types",
    "clean-all": "rimraf node_modules && rimraf dist && rimraf tsconfig.tsbuildinfo",
    "release": "pnpm build && yarn publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest"
  },
  "peerDependencies": {
    "next-auth": "^4.24.11",
    "react": "19.1.1",    
    "next": "15.5.3"
  },
  "peerDependenciesMeta": {
    "next-auth": { "optional": false }
  },
  "devDependencies": {    
    "@types/node": "24.5.1",
    "next-auth": "^4.24.11",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.9.2"
  },  
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["igrp", "framework", "nextjs", "auth"]
}
