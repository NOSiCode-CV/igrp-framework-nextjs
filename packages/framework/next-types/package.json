    "release": "pnpm build && yarn publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "next-auth": "^4.24.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.x.x"
  }
}
