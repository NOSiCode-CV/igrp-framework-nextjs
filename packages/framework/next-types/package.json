{
  "name": "@igrp/framework-next-types",
  "version": "0.1.0-beta.141",
  "type": "module",
  "description": "IGRP Framework for Next.js | Types",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "types"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "rimraf dist && rimraf tsconfig.tsbuildinfo && pnpm format && tsc -b",
    "format": "prettier --write .",
    "release": "pnpm build && pnpm publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest --no-git-checks",
    "clean-all": "rimraf node_modules && rimraf dist && rimraf tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "next-auth": "4.24.14"
  },
  "dependencies": {
    "@igrp/framework-next-auth": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "next-auth": "4.24.14",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.x.x"
  },
  "publishConfig": {
    "registry": "https://sonatype.nosi.cv/repository/igrp/",
    "tag": "latest",
    "access": "public"
  }
}
