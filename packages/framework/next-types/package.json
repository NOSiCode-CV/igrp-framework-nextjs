{
  "name": "@igrp/framework-next-types",
  "version": "0.0.1-alpha.30",
  "type": "module",
  "description": "IGRP Framework for Next.js | Types",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "types"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "rimraf dist && rimraf tsconfig.tsbuildinfo && pnpm format && tsc -b",
