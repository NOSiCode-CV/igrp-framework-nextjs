{
  "name": "@igrp/framework-next-ui",
  "version": "0.1.0-beta.161",
  "description": "IGRP Framework for Next.js | Design System components",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "layout",
    "components",
    "client side"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+http://git.nosi.cv/igrp-3_0/igrp-framework-frontend/igrp-framework-nextjs.git",
    "directory": "packages/framework/next-ui"
  },
  "homepage": "https://igrp.cv",
  "bugs": {
    "url": "http://git.nosi.cv/igrp-3_0/igrp-framework-frontend/igrp-framework-nextjs/-/issues"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "pnpm build:reactcompiler",
    "build:babel": "rimraf dist_optimized && babel dist --out-dir dist_optimized --source-maps --extensions .ts,.js,.tsx,.jsx,.cjs,.mjs && rimraf dist && move-cli dist_optimized dist && cpy src/*.css dist/",
    "build:reactcompiler": "rimraf dist && rimraf tsconfig.tsbuildinfo && pnpm build:swc && pnpm build:babel && pnpm build:types",
    "build:swc": "swc ./src -d dist --config-file .swcrc --strip-leading-paths && cpy src/*.css dist/",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/",
    "build:without_reactcompiler": "rimraf dist && rimraf tsconfig.tsbuildinfo && pnpm build:types && pnpm build:swc",
    "clean": "pnpm clean:dist && pnpm clean:packages",
    "clean:dist": "rimraf {dist,*.tsbuildinfo}",
    "clean:packages": "rimraf node_modules",
    "format": "prettier --write .",
    "release": "pnpm format && pnpm build && pnpm publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest --no-git-checks",
    "clean-all": "rimraf node_modules && rimraf dist && rimraf tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "next": "^15.5.0",
    "next-auth": "^4.24.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "dependencies": {
    "@igrp/framework-next-auth": "workspace:*",
    "@igrp/framework-next-types": "workspace:*",
    "@igrp/igrp-framework-react-design-system": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "next-themes": "0.4.6",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "tailwindcss": "4.3.1",
    "@babel/cli": "8.0.1",
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/preset-react": "8.0.1",
    "@babel/preset-typescript": "8.0.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.43",
    "@types/babel__preset-env": "7.10.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "cpy-cli": "7.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "move-cli": "2.0.0",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens": "./dist/tokens.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://sonatype.nosi.cv/repository/igrp/",
    "tag": "latest",
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  }
}
