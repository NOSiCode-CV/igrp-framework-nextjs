{
  "name": "@igrp/framework-next-ui",
  "version": "0.0.0-alpha.13",
  "description": "IGRP Framework for Next.js - Layout components and data loading hooks",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "admin",
    "layout",
    "components"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": {
      "import": "./dist/styles.css"
    },
    "./index.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "clean": "pnpm clean:dist && pnpm clean:packages",
    "clean:dist": "rimraf dist dist_optimized dist_types",
    "clean:packages": "rimraf node_modules",
    "build:types": "rimraf dist_types && tsc --emitDeclarationOnly --outDir dist_types",
    "build:swc": "swc ./src -d dist --config-file .swcrc --strip-leading-paths && cpy src/*.css dist/",
    "build:babel": "rimraf dist_optimized && babel dist --out-dir dist_optimized --source-maps --extensions .ts,.js,.tsx,.jsx,.cjs,.mjs --ignore '**/*.d.ts' && rimraf dist && move dist_optimized dist && cpy src/*.css dist/",
    "build:prod": "pnpm clean:dist && pnpm tailwind:build && pnpm build:types && pnpm build:swc && pnpm build:babel && cpy dist_types/**/*.d.ts dist/ && rimraf dist_types",
    "format": "prettier --write .",
    "tailwind:build": "pnpm dlx @tailwindcss/cli -i ./src/index.css -o ./src/styles.css",
    "release": "pnpm format && pnpm build:prod && yarn publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest"
  },
  "peerDependencies": {
    "next": "15.3.4",
    "next-auth": "^4.24.11",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "@bprogress/next": "^3.2.12",
    "@hookform/resolvers": "^5.0.1",
    "@igrp/framework-next-types": "latest",
    "@igrp/igrp-framework-react-design-system": "latest",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.81.2",
    "@tanstack/react-query-devtools": "^5.81.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "culori": "^4.0.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.518.0",
    "next-intl": "^4.1.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.4.3",
    "posthog-js": "^1.236.1",
    "react-day-picker": "^9.6.7",
    "react-hook-form": "^7.55.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.2",
    "screenfull": "^6.0.2",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^3.25.67",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.4",
    "@babel/core": "^7.24.4",
    "@babel/preset-env": "^7.24.4",
    "@babel/preset-react": "^7.24.4",
    "@babel/preset-typescript": "^7.24.4",
    "@ngard/tiny-isequal": "^1.1.0",
    "@swc/cli": "^0.3.0",
    "@swc/core": "^1.4.0",
    "@types/culori": "^2.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "19.1.0-rc.2",
    "cpy-cli": "^5.0.0",
    "move-cli": "^2.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3"
  }
}
