{
  "name": "@igrp/framework-next-ui",
  "version": "0.1.0-beta.147",
  "description": "IGRP Framework for Next.js | Design System components",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "layout",
    "components",
    "client side"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "scripts": {
    "dev": "tsc --watch",
    "build": "pnpm build:reactcompiler",
    "build:babel": "rimraf dist_optimized && babel dist --out-dir dist_optimized --source-maps --extensions .ts,.js,.tsx,.jsx,.cjs,.mjs && rimraf dist && move dist_optimized dist && cpy src/*.css dist/",
    "build:reactcompiler": "rimraf dist && rimraf tsconfig.tsbuildinfo && pnpm tailwind:build && pnpm build:swc && pnpm build:babel && pnpm build:types",
    "build:swc": "swc ./src -d dist --config-file .swcrc --strip-leading-paths && cpy src/*.css dist/",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/",
    "build:without_reactcompiler": "rimraf dist && rimraf tsconfig.tsbuildinfo && pnpm build:types && pnpm build:swc",
    "clean": "pnpm clean:dist && pnpm clean:packages",
    "clean:dist": "rimraf {dist,*.tsbuildinfo}",
    "clean:packages": "rimraf node_modules",
    "format": "prettier --write .",
    "tailwind:build": "pnpm dlx @tailwindcss/cli -i ./src/index.css -o ./src/styles.css",
    "release": "pnpm format && pnpm build && pnpm publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest --no-git-checks",
    "clean-all": "rimraf node_modules && rimraf dist && rimraf tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "next": "15.5.19",
    "next-auth": "4.24.14",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "dependencies": {
    "@igrp/framework-next-auth": "workspace:*",
    "@igrp/framework-next-types": "workspace:*",
    "@igrp/igrp-framework-react-design-system": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "next-themes": "0.4.6",
    "tailwindcss": "4.3.0",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/cli": "7.29.7",
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-react": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.40",
    "@tailwindcss/cli": "^4.3.0",
    "@types/babel__preset-env": "7.10.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "cpy-cli": "7.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "move-cli": "^2.0.0",
    "postcss": "8.5.15",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens": "./dist/tokens.css",
    "./styles": "./dist/styles.css"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./tokens": "./dist/tokens.css",
      "./styles": "./dist/styles.css"
    },
    "registry": "https://sonatype.nosi.cv/repository/igrp/",
    "tag": "latest",
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.x.x"
  }
}
