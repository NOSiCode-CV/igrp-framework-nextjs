{
  "name": "@igrp/framework-next",
  "version": "0.0.1-alpha.32",
  "description": "IGRP Framework for Next.js | Server Rendering components",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "layout",
    "components",
    "server side"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "scripts": {
    "dev": "tsc --watch",
    "clean": "pnpm clean:packages && pnpm clean:dist",
    "clean:dist": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "clean:packages": "rimraf node_modules",
    "build": "pnpm format && pnpm build:reactcompiler",
    "build:babel": "rimraf dist_optimized && babel dist --out-dir dist_optimized --source-maps --extensions .ts,.js,.tsx,.jsx,.cjs,.mjs && rimraf dist && move dist_optimized dist",
    "build:reactcompiler": "pnpm clean:dist && pnpm build:swc && pnpm build:babel && pnpm build:types",
    "build:swc": "swc ./src -d dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:without_reactcompiler": "pnpm clean:dist && pnpm build:swc && pnpm build:types",
    "format": "prettier --write .",
    "release": "pnpm build && yarn publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest"
  },
  "peerDependencies": {
    "next": "15.4.5",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "dependencies": {
    "@bprogress/next": "^3.2.12",
    "@igrp/framework-next-types": "workspace:*",
    "@igrp/framework-next-ui": "workspace:*",
    "@igrp/platform-access-management-client-ts": "0.0.1-alpha.5",
    "clsx": "^2.1.1",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@babel/cli": "7.28.0",
    "@babel/core": "7.28.0",
    "@babel/preset-env": "7.28.0",
    "@babel/preset-react": "7.27.1",
    "@babel/preset-typescript": "7.27.1",
    "@eslint/js": "^9.31.0",
    "@swc/cli": "0.7.8",
    "@swc/core": "^1.13.1",
    "@types/node": "^24.1.0",
    "@types/react": "19.1.9",
    "@types/react-dom": "19.1.7",
    "babel-plugin-react-compiler": "19.1.0-rc.2",
    "cpy-cli": "5.0.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.0.0",
    "move-cli": "^2.0.0",
    "prettier": "3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.x.x"
  }
}
