{
  "name": "@igrp/framework-next",
  "version": "0.0.0-alpha.5",
  "description": "IGRP Framework for Next.js - Layout components and data loading hooks",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "admin",
    "layout",
    "components"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "scripts": {
    "dev": "tsc --watch",
    "clean": "pnpm clean:dist && pnpm clean:packages",
    "clean:dist": "rimraf dist",
    "clean:packages": "rimraf node_modules",
    "build:swc": "swc ./src -d dist --config-file .swcrc --strip-leading-paths",
    "build:babel": "rimraf dist_optimized && babel dist --out-dir dist_optimized --source-maps --extensions .ts,.js,.tsx,.jsx,.cjs,.mjs && rimraf dist && move dist_optimized dist",
    "build:prod": "pnpm build:swc && pnpm build:babel",
    "release": "yarn publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest",
    "format": "prettier --write ."
  },
  "peerDependencies": {
    "next": "15.3.3",    
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "@bprogress/next": "^3.2.12",
    "@hookform/resolvers": "^5.1.1",    
    "@igrp/framework-next-types": "0.0.0-alpha.5",
    "@igrp/framework-next-ui": "0.0.0-alpha.5",
    "@igrp/platform-access-management-client-ts": "0.0.1-alpha.4",
    "clsx": "^2.1.1",    
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.4",
    "@babel/core": "^7.24.4",
    "@babel/preset-env": "^7.24.4",
    "@babel/preset-react": "^7.24.4",
    "@babel/preset-typescript": "^7.24.4",
    "@eslint/js": "^9.25.0",
    "@swc/cli": "^0.3.0",
    "@swc/core": "^1.4.0",
    "@types/node": "^24.0.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "babel-plugin-react-compiler": "19.1.0-rc.2",
    "cpx": "^1.5.0",
    "cpy-cli": "^5.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "move-cli": "^2.0.0",
    "prettier": "3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1"
  },
  "type": "module",
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ]
}
