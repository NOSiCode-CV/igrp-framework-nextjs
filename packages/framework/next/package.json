{
  "name": "@igrp/framework-next",
  "version": "0.1.0-beta.111-1",
  "description": "IGRP Framework for Next.js | Server Rendering components",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "layout",
    "components",
    "server-side"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "scripts": {
    "dev": "tsc --watch",
    "clean": "pnpm clean:packages && pnpm clean:dist",
    "clean:dist": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "clean:packages": "rimraf node_modules",
    "build": "pnpm format && pnpm build:reactcompiler",
    "build:babel": "rimraf dist_optimized && babel dist --out-dir dist_optimized --source-maps --extensions .ts,.js,.tsx,.jsx,.cjs,.mjs && rimraf dist && move dist_optimized dist",
    "build:reactcompiler": "pnpm clean:dist && pnpm build:swc && pnpm build:babel && pnpm build:types",
    "build:swc": "swc ./src -d dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:without_reactcompiler": "pnpm clean:dist && pnpm build:swc && pnpm build:types",
    "format": "prettier --write .",
    "release": "pnpm build && yarn publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag next",
    "clean-all": "rimraf node_modules && rimraf dist && rimraf tsconfig.tsbuildinfo"
  },
  "peerDependencies": {},
  "dependencies": {
    "next": "^15.5.14",
    "react": "^19.2.4",
    "react-dom": "19.2.4",
    "@igrp/framework-next-auth": "0.1.0-beta.111-1",
    "@igrp/framework-next-types": "0.1.0-beta.111-1",
    "@igrp/framework-next-ui": "0.1.0-beta.111-1",
    "@igrp/platform-access-management-client-ts": "0.1.0-beta.64"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@eslint/js": "^9.39.2",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.11",
    "@types/node": "^24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "cpy-cli": "7.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "move-cli": "^2.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.x.x"
  }
}
