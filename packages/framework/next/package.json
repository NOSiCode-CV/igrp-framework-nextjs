{
  "name": "@igrp/framework-next",
  "version": "0.1.0-beta.23",
  "description": "IGRP Framework for Next.js | Server Rendering components",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "layout",
    "components",
    "server side"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "scripts": {
    "dev": "tsc --watch",
    "clean": "pnpm clean:packages && pnpm clean:dist",
    "clean:dist": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "clean:packages": "rimraf node_modules",
    "build": "pnpm format && pnpm build:reactcompiler",
    "build:babel": "rimraf dist_optimized && babel dist --out-dir dist_optimized --source-maps --extensions .ts,.js,.tsx,.jsx,.cjs,.mjs && rimraf dist && move dist_optimized dist",
    "build:reactcompiler": "pnpm clean:dist && pnpm build:swc && pnpm build:babel && pnpm build:types",
    "build:swc": "swc ./src -d dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:without_reactcompiler": "pnpm clean:dist && pnpm build:swc && pnpm build:types",
    "format": "prettier --write .",
    "release": "pnpm build && yarn publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest",
    "clean-all": "rimraf node_modules && rimraf dist && rimraf tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "next": "15.5.5",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "dependencies": {
    "@igrp/framework-next-types": "0.1.0-beta.23",
    "@igrp/framework-next-ui": "0.1.0-beta.23",
    "@igrp/framework-next-auth": "0.1.0-beta.23",
    "@igrp/platform-access-management-client-ts": "0.1.0-beta.40",
    "clsx": "^2.1.1",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@babel/cli": "7.28.3",
    "@babel/core": "7.28.4",
    "@babel/preset-env": "7.28.3",
    "@babel/preset-react": "7.27.1",
    "@babel/preset-typescript": "7.27.1",
    "@eslint/js": "^9.32.0",
    "@swc/cli": "0.7.8",
    "@swc/core": "^1.13.1",
    "@types/node": "^24.5.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "cpy-cli": "6.0.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "move-cli": "^2.0.0",
    "prettier": "3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.x.x"
  }
}
