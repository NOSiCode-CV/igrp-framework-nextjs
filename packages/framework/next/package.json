{
  "name": "@igrp/framework-next",
  "version": "0.1.0-beta.161",
  "description": "IGRP Framework for Next.js | Server Rendering components",
  "keywords": [
    "igrp",
    "framework",
    "nextjs",
    "layout",
    "components",
    "server-side"
  ],
  "author": "IGRP Team",
  "license": "MIT",
  "scripts": {
    "dev": "tsc --watch",
    "clean": "pnpm clean:packages && pnpm clean:dist",
    "clean:dist": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "clean:packages": "rimraf node_modules",
    "build": "pnpm format && pnpm build:reactcompiler",
    "build:babel": "rimraf dist_optimized && babel dist --out-dir dist_optimized --source-maps --extensions .ts,.js,.tsx,.jsx,.cjs,.mjs && rimraf dist && move dist_optimized dist",
    "build:reactcompiler": "pnpm clean:dist && pnpm build:swc && pnpm build:babel && pnpm build:types",
    "build:swc": "swc ./src -d dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:without_reactcompiler": "pnpm clean:dist && pnpm build:swc && pnpm build:types",
    "format": "prettier --write .",
    "release": "pnpm build && pnpm publish --registry=https://sonatype.nosi.cv/repository/igrp/ --tag latest --no-git-checks",
    "clean-all": "rimraf node_modules && rimraf dist && rimraf tsconfig.tsbuildinfo",
    "test": "vitest run"
  },
  "dependencies": {
    "next": "15.5.19",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "@igrp/framework-next-auth": "workspace:*",
    "@igrp/framework-next-types": "workspace:*",
    "@igrp/framework-next-ui": "workspace:*",
    "@igrp/platform-access-management-client-ts": "0.2.0-beta.11",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/cli": "8.0.1",
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/preset-react": "8.0.1",
    "@babel/preset-typescript": "8.0.1",
    "@eslint/js": "9.39.4",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.43",
    "@types/node": "25.9.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "cpy-cli": "7.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "move-cli": "2.0.0",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./app-error": {
      "import": "./dist/app-error.js",
      "types": "./dist/app-error.d.ts",
      "default": "./dist/app-error.js"
    },
    "./logger": {
      "import": "./dist/logger.js",
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    },
    "./actions": {
      "import": "./dist/actions/index.js",
      "types": "./dist/actions/index.d.ts",
      "default": "./dist/actions/index.js"
    },
    "./client": {
      "import": "./dist/client/use-layout-data.js",
      "types": "./dist/client/use-layout-data.d.ts",
      "default": "./dist/client/use-layout-data.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.x.x"
  },
  "publishConfig": {
    "registry": "https://sonatype.nosi.cv/repository/igrp/",
    "tag": "latest",
    "access": "public"
  }
}
