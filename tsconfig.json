{
  "compilerOptions": {
    "target": "ES2023",
    "module": "commonjs",
    "lib": [
      "es2023"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "declaration": true,
